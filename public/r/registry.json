      "title": "Lemma Assistant Experience",
      "description": "A stock assistant experience UI powered by useAssistantController from lemma-sdk/react.",
      "dependencies": [
        "lemma-sdk",
        "react-markdown",
        "remark-gfm",
        "clsx",
        "tailwind-merge",
        "radix-ui"
      ],
      "cssVars": {
