{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "lemma-assistant-experience",
  "type": "registry:block",
  "title": "Lemma Assistant Experience",
  "description": "A stock assistant experience UI powered by useAssistantController from lemma-sdk/react.",
  "dependencies": ["lemma-sdk", "react-markdown", "remark-gfm"],
  "files": [
    {
      "path": "registry/default/lemma-assistant-experience/components/assistant-types.ts",
      "type": "registry:component",
      "target": "components/lemma/assistant/assistant-types.ts"
    },
    {
      "path": "registry/default/lemma-assistant-experience/components/assistant-chrome.tsx",
      "type": "registry:component",
      "target": "components/lemma/assistant/assistant-chrome.tsx"
    },
    {
      "path": "registry/default/lemma-assistant-experience/components/assistant-experience.tsx",
      "type": "registry:component",
      "target": "components/lemma/assistant/assistant-experience.tsx"
    },
    {
      "path": "registry/default/lemma-assistant-experience/styles/lemma-assistant.css",
      "type": "registry:file",
      "target": "styles/lemma-assistant.css"
    }
  ]
}
