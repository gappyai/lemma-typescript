{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "lemma-workflow-start-form",
  "type": "registry:block",
  "title": "Lemma Workflow Start Form",
  "description": "A schema-aware launcher for manual or input-driven workflows using useWorkflowStart.",
  "dependencies": ["lemma-sdk"],
  "registryDependencies": ["button", "card", "checkbox", "input", "label", "select", "textarea"],
  "files": [
    {
      "path": "registry/default/lemma-workflow-start-form/components/lemma-schema-form.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-schema-form.tsx"
    },
    {
      "path": "registry/default/lemma-workflow-start-form/components/lemma-workflow-start-form.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-workflow-start-form.tsx"
    }
  ]
}
