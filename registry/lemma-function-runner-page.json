{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "lemma-function-runner-page",
  "type": "registry:block",
  "title": "Lemma Function Runner Page",
  "description": "A function runner page with function selection, run panel, and run history.",
  "dependencies": ["lemma-sdk"],
  "registryDependencies": ["button", "card", "checkbox", "input", "label", "select", "textarea"],
  "files": [
    {
      "path": "registry/default/lemma-schema-form/components/lemma-schema-form.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-schema-form.tsx"
    },
    {
      "path": "registry/default/lemma-function-run-panel/components/lemma-function-run-panel.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-function-run-panel.tsx"
    },
    {
      "path": "registry/default/lemma-function-run-history/components/lemma-function-run-history.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-function-run-history.tsx"
    },
    {
      "path": "registry/default/lemma-function-runner-page/components/lemma-function-runner-page.tsx",
      "type": "registry:component",
      "target": "components/lemma/lemma-function-runner-page.tsx"
    }
  ]
}
